---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHero from '../../components/PageHero.astro'
import { loadData, type Group } from '../../lib/data'

export function getStaticPaths() {
  return loadData.groups().map((g) => ({
    params: { id: g.id },
    props: { group: g },
  }))
}

const { group } = Astro.props as { group: Group }
const eyebrow = group.category?.replace(/_/g, ' ')
---
<BaseLayout title={`${group.name || group.id.toUpperCase()} — ${group.title || ''}`.trim()} description={group.intro || ''}>
  <PageHero variant="detail" bleed eyebrow={eyebrow} title={group.name || group.id.toUpperCase()} lead={group.title} />
  <div class="page page--wide">
    <div class="grp-detail">
      {group.intro && (
        <section>
          <h2>Introduction</h2>
          <div class="prose" set:html={group.intro} />
        </section>
      )}
      {group.scope && (
        <section>
          <h2>Scope</h2>
          <div class="prose" set:html={group.scope} />
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .grp-detail { max-width: 48rem; margin: 2rem auto; padding: 0 1.5rem; }
  .grp-detail h2 {
    font-family: var(--font-serif); font-size: 1.375rem; font-weight: 600;
    color: #1c1917; margin: 2rem 0 0.75rem;
    padding-bottom: 0.375rem; border-bottom: 1px solid #e7e5e4;
  }
  :global(.dark) .grp-detail h2 { color: #fafaf9; border-bottom-color: #44403c; }
  .grp-detail .prose {
    font-size: 1rem; line-height: 1.7; color: #44403c;
    white-space: pre-wrap;
  }
  :global(.dark) .grp-detail .prose { color: #d6d3d1; }
</style>
