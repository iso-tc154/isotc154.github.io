---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHero from '../../components/PageHero.astro'
import { loadData, type Standard } from '../../lib/data'

export function getStaticPaths() {
  return loadData.standards().map((s) => ({
    params: { id: s.id },
    props: { standard: s },
  }))
}

const { standard } = Astro.props as { standard: Standard }
const iso = standard.iso
const tc154 = standard.tc154
const pubYear = iso.publication_date ? new Date(iso.publication_date).getFullYear() : null
const statusLabel = (tc154?.status || '').replace('_', ' ')
const eyebrow = [statusLabel, tc154?.group?.toUpperCase()].filter(Boolean).join(' · ')
---
<BaseLayout title={`${iso.name} — ISO/TC 154`} description={iso.title}>
  <PageHero variant="detail" bleed eyebrow={eyebrow} title={iso.name} lead={iso.title} />

  <div class="page page--wide">
    <div class="std-detail">
      <aside class="std-detail__aside">
        <dl class="fact-list">
          {pubYear && (<><dt>Published</dt><dd>{pubYear}</dd></>)}
          {iso.stage && (<><dt>Stage</dt><dd>{iso.stage}</dd></>)}
          {iso.type && (<><dt>Type</dt><dd>{iso.type}</dd></>)}
          {iso.ics && (<><dt>ICS</dt><dd>{iso.ics}</dd></>)}
          {iso.store_id && (<><dt>ISO Store</dt><dd><a href={`https://www.iso.org/standard/${iso.store_id}.html`}>#{iso.store_id}</a></dd></>)}
          {tc154?.group && (<><dt>Responsible group</dt><dd><a href={`/groups/${tc154.group}/`}>{tc154.group.toUpperCase()}</a></dd></>)}
        </dl>
      </aside>

      <div class="std-detail__main">
        {tc154?.introduction && (
          <section>
            <h2>Editor's introduction</h2>
            <div class="prose" set:html={tc154.introduction} />
          </section>
        )}
        {iso.scope && (
          <section>
            <h2>Scope</h2>
            <p>{iso.scope}</p>
          </section>
        )}
        {tc154?.scope && tc154.scope !== iso.scope && (
          <section>
            <h2>TC 154 scope notes</h2>
            <div class="prose" set:html={tc154.scope} />
          </section>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .std-detail { max-width: 60rem; margin: 2rem auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 768px) { .std-detail { grid-template-columns: 16rem 1fr; } }
  .std-detail__aside { font-size: 0.875rem; }
  .fact-list { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1rem; margin: 0; }
  .fact-list dt { font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #78716c; padding-top: 0.25rem; }
  :global(.dark) .fact-list dt { color: #a8a29e; }
  .fact-list dd { margin: 0; color: #1c1917; }
  :global(.dark) .fact-list dd { color: #fafaf9; }
  .fact-list dd a { color: var(--color-brand); }

  .std-detail__main h2 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: #1c1917;
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid #e7e5e4;
  }
  :global(.dark) .std-detail__main h2 { color: #fafaf9; border-bottom-color: #44403c; }
  .std-detail__main p, .std-detail__main .prose {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #44403c;
  }
  :global(.dark) .std-detail__main p, :global(.dark) .std-detail__main .prose { color: #d6d3d1; }
  .std-detail__main section:first-child h2 { margin-top: 0; }
</style>
