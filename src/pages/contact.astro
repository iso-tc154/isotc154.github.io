---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
import { committee } from '../data/committee'

const committeeUrl = committee.links.isoCommittee
---
<BaseLayout title="Contact — ISO/TC 154" description="Contact details for ISO/TC 154.">
  <PageHero
    variant="index"
    bleed
    eyebrow="Reach the committee"
    title="Contact"
    lead="For questions about ISO/TC 154, our standards, or participation, please see the official ISO committee page for contact details of our Committee Manager and Technical Programme Manager."
  />
  <div class="page page--wide">
    <div class="contact-shell">
      <div class="contact-card">
        <a href={committeeUrl} class="contact-card__link" target="_blank" rel="noopener noreferrer">
          <div class="contact-card__logo">
            <img src="/assets/iso-red.svg" alt="ISO" class="contact-card__iso-logo" />
          </div>
          <div class="contact-card__details">
            <p class="contact-card__name">ISO/TC 154</p>
            <p class="contact-card__role">Committee contact details on ISO.org</p>
            <p class="contact-card__affiliation">Committee Manager · Technical Programme Manager</p>
          </div>
          <svg class="contact-card__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17L17 7M17 7H8M17 7V16" />
          </svg>
        </a>
      </div>

      <section class="secretariat">
        <h2 class="secretariat__title">Secretariat</h2>
        <p class="secretariat__body">
          The ISO/TC 154 secretariat is held by
          <a href="http://www.sac.gov.cn" target="_blank" rel="noopener noreferrer">SAC</a>
          (China). {committee.chair} serves as Chair.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-shell { max-width: 48rem; margin: 2rem auto; padding: 0 1.5rem; }
  .contact-card { margin-bottom: 2.5rem; }
  .contact-card__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    padding: 1.5rem;
    border: 1px solid #e7e5e4;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  :global(.dark) .contact-card__link { border-color: #44403c; background: rgb(15 23 42 / 0.5); }
  .contact-card__link:hover { border-color: var(--color-blue-accent); transform: translateY(-2px); }
  .contact-card__logo img { width: 3rem; height: auto; }
  .contact-card__name { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 600; color: #1c1917; margin: 0; }
  :global(.dark) .contact-card__name { color: #fafaf9; }
  .contact-card__role { font-size: 0.9375rem; color: #57534e; margin: 0.25rem 0 0; }
  :global(.dark) .contact-card__role { color: #d6d3d1; }
  .contact-card__affiliation { font-size: 0.8125rem; color: #78716c; margin: 0.25rem 0 0; }
  :global(.dark) .contact-card__affiliation { color: #a8a29e; }
  .contact-card__arrow { color: var(--color-brand); }
  .secretariat__title { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; color: #1c1917; margin: 0 0 0.75rem; }
  :global(.dark) .secretariat__title { color: #fafaf9; }
  .secretariat__body { font-size: 1rem; line-height: 1.6; color: #44403c; }
  :global(.dark) .secretariat__body { color: #d6d3d1; }
  .secretariat__body a { color: var(--color-brand); }
</style>
